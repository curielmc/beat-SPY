{
  "buildCommand": "npm install && npm run build",
  "redirects": [
    { "source": "/:path*", "has": [{ "type": "host", "value": "beat-spy.vercel.app" }], "destination": "https://beat-snp.com/:path*", "permanent": true },
    { "source": "/:path*", "has": [{ "type": "host", "value": "beat-snp.vercel.app" }], "destination": "https://beat-snp.com/:path*", "permanent": true },
    { "source": "/:path*", "has": [{ "type": "host", "value": "beat-snp-martin-curiels-projects.vercel.app" }], "destination": "https://beat-snp.com/:path*", "permanent": true },
    { "source": "/:path*", "has": [{ "type": "host", "value": "www.beat-snp.com" }], "destination": "https://beat-snp.com/:path*", "permanent": true }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/weekly-ai-insights",
      "schedule": "0 0 * * 0"
    },
    {
      "path": "/api/daily-snapshot",
      "schedule": "0 21 * * 1-5"
    },
    {
      "path": "/api/process-pending-orders",
      "schedule": "*/5 * * * 1-5"
    },
    {
      "path": "/api/cron/fetch-daily-prices",
      "schedule": "15 20 * * *"
    },
    {
      "path": "/api/newsletter-reminder-check",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/fetch-spy-constituents",
      "schedule": "0 22 * * 1-5"
    },
    {
      "path": "/api/cron/challenge-lifecycle",
      "schedule": "5 13 * * 1-5"
    }
  ]
}
